<Window x:Class="LIBRARY.StudentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LIBRARY"
        mc:Ignorable="d"
Title="Мій кабінет" Height="500" Width="600">
    <TabControl>
        <TabItem Header="Мої книги">
            <StackPanel Margin="10">
                <TextBlock Text="Ваші поточні борги:" FontWeight="Bold" Margin="0,0,0,10"/>
                <DataGrid x:Name="dgMyLoans" IsReadOnly="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Книга" Binding="{Binding book_title}" Width="*"/>
                        <DataGridTextColumn Header="Взято" Binding="{Binding loan_date, StringFormat=dd.MM.yyyy}"/>
                        <DataGridTextColumn Header="Повернути до" Binding="{Binding return_date, StringFormat=dd.MM.yyyy}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </TabItem>
        <TabItem Header="Каталог книг">
            <DataGrid x:Name="dgCatalog" IsReadOnly="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Назва" Binding="{Binding title}" Width="*"/>
                    <DataGridTextColumn Header="Автор" Binding="{Binding author_name}" Width="*"/>
                    <DataGridTextColumn Header="Категорія" Binding="{Binding category_name}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
    </TabControl>
</Window>
