<Window x:Class="LIBRARY.AddAuthorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LIBRARY.MODEL"
        mc:Ignorable="d"
    Title="Новий автор" Height="220" Width="300" WindowStartupLocation="CenterOwner">
    <Grid>
        <StackPanel>
            <TextBlock Text="Повне ім'я автора:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="txtFullName" Margin="0,0,0,10" Height="25"/>

            <TextBlock Text="Країна:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="txtCountry" Margin="0,0,0,15" Height="25"/>

            <Button Content="Додати автора" Click="btnAdd_Click" Height="30" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
