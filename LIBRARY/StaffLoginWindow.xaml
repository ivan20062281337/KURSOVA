<Window x:Class="LIBRARY.StaffLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LIBRARY"
        mc:Ignorable="d"
        Title="Вхід для персоналу" Height="250" Width="350" WindowStartupLocation="CenterScreen">
        <StackPanel Margin="15" VerticalAlignment="Center">
        <TextBlock Text="Логін (MySQL User):" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="txtUser" Margin="0,0,0,10" Height="25"/>

        <TextBlock Text="Пароль:" Margin="0,0,0,5" FontWeight="Bold"/>
        <PasswordBox x:Name="txtPass" Margin="0,0,0,20" Height="25"/>

        <Button x:Name="btnLogin" Content="Увійти в систему" Height="35" 
                Background="#FF2196F3" Foreground="White" Click="btnLogin_Click"/>

        <Button Content="Назад" Margin="50,10,50,0" Click="btnBack_Click"/>
    </StackPanel>
</Window>
