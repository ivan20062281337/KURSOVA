<Window x:Class="LIBRARY.AddStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LIBRARY"
        mc:Ignorable="d"
        Title="Реєстрація нового студента" Height="230" Width="350" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="ПІБ Студента:" Margin="0,0,0,5"/>
        <TextBox x:Name="txtName" Margin="0,0,0,15" Height="25"/>

        <TextBlock Text="Електронна пошта:" Margin="0,0,0,5"/>
        <TextBox x:Name="txtEmail" Margin="0,0,0,20" Height="25"/>

        <Button Content="Зареєструвати" Click="btnRegister_Click" 
                Height="40" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
    </StackPanel>
</Window>
